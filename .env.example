POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
POSTGRES_PORT=5432

REDIS_PORT=6379

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
LOG_LEVEL=INFO

APP_NAME=Crypto Trading Research Bot
APP_ENV=local
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://trading:trading@postgres:5432/trading
REDIS_URL=redis://redis:6379/0
MARKET_DATA_EXCHANGE=binance
MARKET_DATA_SYMBOLS=BTC/USDT,ETH/USDT
MARKET_DATA_TIMEFRAMES=1h,4h
MARKET_DATA_DEFAULT_FETCH_LIMIT=500

RISK_MODE=paper
RISK_INITIAL_BALANCE=1000
RISK_PER_TRADE_PERCENT=1
RISK_MAX_DAILY_LOSS_PERCENT=5
RISK_MAX_TOTAL_DRAWDOWN_PERCENT=15
RISK_MAX_OPEN_POSITIONS=1
RISK_REQUIRE_STOP_LOSS=true
RISK_SLIPPAGE_PERCENT=0.05
RISK_FEE_PERCENT=0.1
RISK_ATR_STOP_MULTIPLIER=2.0
RISK_REWARD_TO_RISK_RATIO=2.5
RISK_USE_REAL_TRADING=false

STRATEGY_DEFAULT_NAME=rsi_ema_trend_multi_v1
STRATEGY_RSI_EMA_V1_BUY_RSI_MAX=35
STRATEGY_RSI_EMA_V1_SELL_RSI_MIN=65
STRATEGY_RSI_EMA_V1_REQUIRE_MACD_IMPROVING=true
STRATEGY_RSI_EMA_V2_BUY_RSI_MAX=40
STRATEGY_RSI_EMA_V2_SELL_RSI_MIN=58
STRATEGY_RSI_EMA_V2_REQUIRE_MACD_IMPROVING=false
STRATEGY_RSI_EMA_MULTI_V1_TREND_PERIOD=100
STRATEGY_RSI_EMA_MULTI_V1_BUY_RSI_MAX=40
STRATEGY_RSI_EMA_MULTI_V1_SELL_RSI_MIN=58
STRATEGY_RSI_EMA_MULTI_V1_REQUIRE_MACD_IMPROVING=false
STRATEGY_SYMBOL_OVERRIDES=BTC/USDT:rsi_ema_trend_v2,ETH/USDT:rsi_ema_trend_multi_v1
AUTOMATION_ENABLED=true
AUTOMATION_ACCOUNT_NAME=paper-main
AUTOMATION_LOOP_INTERVAL_SECONDS=300
AUTOMATION_EXECUTION_TIMEFRAMES=1h
DAILY_REPORT_ENABLED=true
DAILY_REPORT_ACCOUNT_NAME=paper-main
DAILY_REPORT_TIMEZONE=Europe/Kiev
DAILY_REPORT_TIME_LOCAL=09:00

TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_NAME=
TELEGRAM_USERNAME=

ML_MODELS_DIR=ml/models
ML_DATASETS_DIR=ml/datasets
ML_DEFAULT_CONFIDENCE_THRESHOLD=0.60
ML_DEFAULT_TARGET=future_edge_long
ML_DEFAULT_FORECAST_HORIZON_CANDLES=3
ML_DEFAULT_MIN_EDGE_PERCENT=0.40
ML_DEFAULT_MIN_PRECISION=0.40
ML_DEFAULT_MIN_POSITIVE_PREDICTIONS=12
ML_TRAIN_RATIO=0.60
ML_VALIDATION_RATIO=0.20
ML_TEST_RATIO=0.20
ML_MIN_ROWS=120
ML_RISK_FILTER_ENABLED=false
ML_RISK_FILTER_REQUIRE_MODEL=false
ML_RISK_FILTER_CONFIDENCE_THRESHOLD=0.60
ML_RISK_FILTER_SYMBOLS=BTC/USDT
